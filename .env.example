# ═══════════════════════════════════════════════════════════════════════
#                       LLM CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════
# Two providers can be configured independently:
#   LLM_PROVIDER  → memory extraction at session end (inside the package)
#   CHAT_PROVIDER → the agent's chat model (in examples/agent.py)
# If CHAT_PROVIDER is not set, it falls back to LLM_PROVIDER.
# Each provider supports: openai, groq, anthropic, gemini, ollama, litellm
# Plus chat-only: bedrock (via langchain-aws)
# ═══════════════════════════════════════════════════════════════════════

LLM_PROVIDER=openai
# CHAT_PROVIDER=openai          # uncomment to override the chat provider

CHAT_MODEL=gpt-4o
MEMORY_EXTRACTION_MODEL=gpt-4o-mini

# ─── OpenAI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=               # only set for OpenAI-compatible servers (LM Studio, vLLM, etc.)

# ─── Groq ────────────────────────────────────────────────────────────────
# https://console.groq.com/keys
# GROQ_API_KEY=gsk_your_key_here
# Recommended models:
#   openai/gpt-oss-120b       (best tool calling — agents)
#   openai/gpt-oss-20b        (faster, smaller TPM footprint)
#   llama-3.3-70b-versatile   (best for JSON extraction)
#   llama-3.1-8b-instant      (cheapest)

# ─── Anthropic (Claude) ──────────────────────────────────────────────────
# https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# Models:
#   claude-3-5-sonnet-latest      (chat — best quality)
#   claude-3-5-haiku-latest       (extraction — cheap + fast)

# ─── Gemini (Google) ─────────────────────────────────────────────────────
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-key-here
# Models:
#   gemini-1.5-pro
#   gemini-1.5-flash              (cheap)

# ─── Ollama (local, free) ────────────────────────────────────────────────
# Run: ollama serve  (and: ollama pull llama3.1:8b)
# OLLAMA_BASE_URL=http://localhost:11434
# Set CHAT_MODEL / MEMORY_EXTRACTION_MODEL to e.g. "llama3.1:8b" or "qwen2.5:14b"

# ─── AWS Bedrock (chat only) ─────────────────────────────────────────────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# Set CHAT_MODEL to e.g. "anthropic.claude-3-5-sonnet-20240620-v1:0"

# ─── LiteLLM (universal — 100+ providers) ────────────────────────────────
# pip install memoryos[litellm]
# Set LLM_PROVIDER=litellm and use "provider/model" strings:
#   MEMORY_EXTRACTION_MODEL=anthropic/claude-3-5-haiku-20241022
#   MEMORY_EXTRACTION_MODEL=bedrock/anthropic.claude-3-haiku-20240307-v1:0
#   MEMORY_EXTRACTION_MODEL=vertex_ai/gemini-1.5-flash
#   MEMORY_EXTRACTION_MODEL=cohere/command-r
#   MEMORY_EXTRACTION_MODEL=together_ai/meta-llama/Llama-3-70b-chat-hf

# ═══════════════════════════════════════════════════════════════════════
#                       GRAPH BACKEND
# ═══════════════════════════════════════════════════════════════════════

GRAPH_BACKEND=neo4j      # or "memgraph"

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=memoryos

MEMGRAPH_URI=bolt://localhost:7688
MEMGRAPH_USERNAME=
MEMGRAPH_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════
#                       REDIS
# ═══════════════════════════════════════════════════════════════════════

REDIS_URL=redis://localhost:6380
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════
#                       OPTIONAL — DEMO APP ONLY
# ═══════════════════════════════════════════════════════════════════════

TAVILY_API_KEY=                # for the web_search tool

API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
